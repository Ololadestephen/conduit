# Conduit Environment Variables
# Copy this file to .env.local and fill in your values

# ===================
# REQUIRED
# ===================

# Upstash Redis - for rate limiting and durable completed run records
# Get these from: https://console.upstash.com/
KV_REST_API_URL=https://your-redis-instance.upstash.io
KV_REST_API_TOKEN=your_upstash_token_here

# AI execution
# B.AI is the primary provider. It uses an OpenAI-compatible chat endpoint.
AI_PROVIDER=b-ai
AI_PROVIDER_ORDER=b-ai,openrouter,groq,ollama
B_AI_BASE_URL=https://api.b.ai
B_AI_MODEL=gpt-5-mini
B_AI_FALLBACK_MODEL=deepseek-v3.2
# Optional. Off by default so empty primary responses fall through instead of
# making a second billable call on the same model.
B_AI_RETRY_EMPTY_RESPONSE=false
# Hard cap for each AI provider request so workflows do not hang for minutes.
AI_REQUEST_TIMEOUT_MS=20000
# Optional hard cap for each workflow agent step. Leave unset to use per-agent defaults.
# WORKFLOW_AGENT_TIMEOUT_MS=75000
B_AI_API_KEY=your_b_ai_api_key_here
OPENROUTER_MODEL=qwen/qwen3-14b:free
OPENROUTER_API_KEY=your_openrouter_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=your_groq_api_key_here
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

# Optional live market context lookup.
# Add one of these so vague market prompts can resolve current participants/outcomes.
TAVILY_API_KEY=
SERPER_API_KEY=

# Pinata - for IPFS workflow storage
# Get this from: https://app.pinata.cloud/developers/api-keys
PINATA_JWT=your_pinata_jwt_token_here

# ===================
# OPTIONAL
# ===================

# WalletConnect Project ID
# Get this from: https://cloud.walletconnect.com/
# Falls back to 'demo' if not set (limited functionality)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Arc Network RPC / USDC
# Default public RPC is shown below. For the Agora/Canteen hackathon flow, run:
#   uv tool install git+https://github.com/the-canteen-dev/ARC-cli.git
#   arc-canteen login
#   arc-canteen rpc-url
# Then paste the printed tokenized RPC URL into .env.local only:
#   https://rpc.testnet.arc-node.thecanteenapp.com/v1/<key>
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
# Optional. If unset, the app derives a websocket URL from NEXT_PUBLIC_ARC_RPC_URL.
NEXT_PUBLIC_ARC_WS_URL=
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
NEXT_PUBLIC_ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Circle Agent Wallet execution
# Create a Testnet API Key with Standard Key access in Circle Console.
CIRCLE_API_KEY=your_circle_testnet_standard_api_key_here
CIRCLE_ENTITY_SECRET=your_circle_entity_secret_here
CIRCLE_BLOCKCHAIN=ARC-TESTNET
CIRCLE_AGENT_WALLET_ID=
CIRCLE_AGENT_WALLET_ADDRESS=
# Optional. Leave blank unless Circle support/console exposes the Arc USDC token ID directly.
CIRCLE_ARC_USDC_TOKEN_ID=

# Seller wallet address for receiving payments
# Fallback seller. Per-agent seller variables below default to this address.
SELLER_ADDRESS=0x_your_arc_wallet_address_here
NEXT_PUBLIC_DEMO_SELLER_ADDRESS=0x_your_arc_wallet_address_here

# Optional per-agent seller wallets for marketplace-style payment routing.
# Leave blank to route that agent to NEXT_PUBLIC_DEMO_SELLER_ADDRESS.
NEXT_PUBLIC_SUMMARIZER_SELLER_ADDRESS=
NEXT_PUBLIC_TRANSLATOR_SELLER_ADDRESS=
NEXT_PUBLIC_SENTIMENT_SELLER_ADDRESS=
NEXT_PUBLIC_CODE_REVIEWER_SELLER_ADDRESS=
NEXT_PUBLIC_DATA_ENRICHMENT_SELLER_ADDRESS=
NEXT_PUBLIC_JSON_TRANSFORM_SELLER_ADDRESS=
NEXT_PUBLIC_MARKET_RESEARCHER_SELLER_ADDRESS=
NEXT_PUBLIC_PROBABILITY_ESTIMATOR_SELLER_ADDRESS=
NEXT_PUBLIC_KELLY_SIZER_SELLER_ADDRESS=
NEXT_PUBLIC_BETTING_BRIEF_SELLER_ADDRESS=
NEXT_PUBLIC_WEBHOOK_SELLER_ADDRESS=

# Polymarket V2 builder attribution (optional, recommendation-only milestone)
POLYMARKET_BUILDER_CODE=your_builder_code_here
NEXT_PUBLIC_POLYMARKET_BUILDER_CODE=your_builder_code_here
